{
  "manifest_version": 3,
  "name": "AutoFill Brasil",
  "version": "1.0.0",
  "description": "Preencha formulários automaticamente com seus dados pessoais (CPF, RG, e-mail e muito mais).",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoFill Brasil"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
